    {
      "parameters": {
        "jsCode": "const contractors = $(\"Get row(s) in sheet\").all().map(i => i.json);\nconst requests = $(\"Parse Claude Output\").all();\n\nreturn requests.map(item => {\n  const request = item.json;\n\n  // Handle Duplicates\n  if (request.is_duplicate === true || request.is_duplicate === \"true\") {\n    return {\n      json: {\n        ...request,\n        contractor_name: \"N/A - Duplicate\",\n        contractor_email: \"N/A\",\n        contractor_id: \"N/A\",\n        duplicate_found: \"Yes\"\n      }\n    };\n  }\n\n  // 🔍 Check exactly what Claude named these fields\n  // We'll look for 'trade_type' OR 'trade' just to be safe\n  const reqTrade = (request.trade_type || request.trade || '').toLowerCase().trim();\n  const reqUrgency = (request.urgency || '').toLowerCase().trim();\n\n  // Find match\n  const match = contractors.find(c => {\n    const cTrade = (c['Trade Type'] || '').toLowerCase().trim();\n    const cTier = (c['Priority Tier'] || '').toLowerCase().trim();\n    return cTrade.includes(reqTrade) && cTier === reqUrgency;\n  });\n\n  return {\n    json: {\n      ...request,\n      contractor_name: match ? match['Contractor Name'] : 'Manual Review Required',\n      contractor_email: match ? match['Contact Email'] : 'N/A',\n      contractor_id: match ? match['Contractor ID'] : 'N/A',\n      duplicate_found: \"No\"\n    }\n  };\n});"
      },
