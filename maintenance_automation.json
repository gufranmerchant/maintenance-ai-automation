    {
      "parameters": {
        "jsCode": "const seen = new Set();\nconst results = [];\n\nfor (const item of $input.all()) {\n  const row = item.json;\n  \n // Remove the Description from the check to catch \"re-worded\" duplicates\n  const identifier = `${row[\"Tenant Name\"]}-${row[\"Unit Number\"]}`.toLowerCase().trim();\n  \n  if (seen.has(identifier)) {\n    // It's a duplicate! Mark it so we can skip it or flag it later.\n    results.push({\n      json: {\n        ...row,\n        is_duplicate: true,\n        workflow_status: \"Duplicate Skipped\"\n      }\n    });\n  } else {\n    // It's a new unique request\n    seen.add(identifier);\n    results.push({\n      json: {\n        ...row,\n        is_duplicate: false,\n        workflow_status: \"Unique Request\"\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
