            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a property management assistant. Classify the following maintenance request.\\n\\nRequest: {{ $json['Request Description'] }}\\n\\nReturn a JSON object with exactly these fields:\\n- urgency: either 'Emergency' or 'Standard'\\n- trade_type: one of 'Plumbing', 'Electrical', 'HVAC', 'General', 'Appliance', 'Roofing/Structure'\\n- reasoning: one sentence explaining your urgency classification.\\n\\nEmergency means: anything that risks safety, flooding, electrical danger, total loss of heat/hot water, or security issues. Everything else is Standard.\\n\\nReturn only the JSON object — no explanation text.\"\n    }\n  ]\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        352,
        -48
      ],
      "id": "b4a36865-3072-4808-afac-3866cad62762",
      "name": "Classify Request with Claude"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Get the text from the current item's Claude response\nconst rawText = $json.content?.[0]?.text || \"\";\n\n// 2. Clean up code fences (```json ... ```) if they exist\nconst cleaned = rawText.replace(/```json|```/g, '').trim();\n\nlet result;\n\ntry {\n  // 3. Attempt to parse the cleaned string into a JSON object\n  result = JSON.parse(cleaned);\n} catch (err) {\n  // 4. Fallback if parsing fails (helps with Section 1: Error Handling)\n  result = {\n    urgency: \"Manual Review Required\",\n    trade_type: \"Unknown\",\n    reasoning: \"Failed to parse AI response. Raw output: \" + rawText.substring(0, 100)\n  };\n}\n\n// 5. Return the result in the format n8n expects\nreturn {\n  urgency: result.urgency,\n  trade_type: result.trade_type,\n  reasoning: result.reasoning\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        -48
      ],
      "id": "6de538c7-68df-4359-8afc-45614fc3ee95",
